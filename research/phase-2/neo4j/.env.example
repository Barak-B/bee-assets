# Copy to .env and fill in.
# DO NOT commit .env to git (.gitignore handles this).

# Generate a strong password:
#   openssl rand -base64 24
NEO4J_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Backup S3/Backblaze credentials (for nightly snapshot to offsite — Phase 5)
# Leave empty for Phase 2; backup is Phase 5.
BACKUP_S3_ENDPOINT=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_BUCKET=
