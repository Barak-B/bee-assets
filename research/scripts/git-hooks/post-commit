#!/usr/bin/env sh
# bee-assets post-commit hook — closes the protocol_hive.md §6 sync loop automatically.
# After each commit: mirror research/**/*.md into the Obsidian vault + re-extract graphify.
#
# Hardened per the 2026-06-26 sync audit (+ 2026-07-11 bash fallback):
#   - skips during rebase / cherry-pick replay (no N-commit fan-out)
#   - prefers PowerShell (pwsh / powershell); falls back to bash sync script
#   - logs to .git/bee-sync.log (NOT /dev/null) so failures are visible; records exit code
#   - the sync scripts are non-destructive to vault edits newer than repo
#
# Cost: per-commit runs incremental `extract` (cheap) and skips the pricier cluster pass.
# Vault-only (skip graphify entirely):
#   export BEE_HOOK_ARGS="-SkipPull -SkipGraphify"          # PowerShell
#   export BEE_HOOK_ARGS="--skip-pull --skip-graphify"      # bash
#
GITDIR="$(git rev-parse --git-dir 2>/dev/null)" || exit 0
REPO="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
PS_SCRIPT="$REPO/research/scripts/sync-vault-and-graphify.ps1"
SH_SCRIPT="$REPO/research/scripts/sync-vault-and-graphify.sh"
LOG="$GITDIR/bee-sync.log"

# Skip during rebase/cherry-pick/revert replay — avoids firing N times for N replayed commits.
if [ -d "$GITDIR/rebase-merge" ] || [ -d "$GITDIR/rebase-apply" ] || [ -f "$GITDIR/CHERRY_PICK_HEAD" ]; then
  exit 0
fi

# Prefer PowerShell when available (Barak's Windows PC — canonical).
PS=""
command -v pwsh >/dev/null 2>&1 && PS=pwsh
[ -z "$PS" ] && command -v powershell >/dev/null 2>&1 && PS=powershell
[ -z "$PS" ] && command -v powershell.exe >/dev/null 2>&1 && PS=powershell.exe

if [ -n "$PS" ] && [ -f "$PS_SCRIPT" ]; then
  ARGS="${BEE_HOOK_ARGS:--SkipPull -SkipCluster -ForceCanon}"
  ( "$PS" -NoProfile -File "$PS_SCRIPT" $ARGS >>"$LOG" 2>&1 ; echo "[$(date '+%Y-%m-%d %H:%M:%S')] sync exit=$? runner=$PS args=$ARGS" >>"$LOG" ) &
  echo "[post-commit] vault+graphify refresh started (PS=$PS) — log: $LOG"
  exit 0
fi

# Bash fallback (WSL / Linux / macOS / cloud dry-run machines).
if [ -f "$SH_SCRIPT" ]; then
  ARGS="${BEE_HOOK_ARGS:---skip-pull --skip-cluster --force-canon}"
  ( bash "$SH_SCRIPT" $ARGS >>"$LOG" 2>&1 ; echo "[$(date '+%Y-%m-%d %H:%M:%S')] sync exit=$? runner=bash args=$ARGS" >>"$LOG" ) &
  echo "[post-commit] vault+graphify refresh started (bash) — log: $LOG"
  exit 0
fi

echo "[post-commit] no sync runner found (need PowerShell or bash script)" | tee -a "$LOG"
exit 0
