  "keywords": {
    "_comment": "Match if tender title or description contains ANY of these. Hebrew + English.",
    "include": [
      "סולארי",
      "סולאר",
      "מערכת סולארית",
      "פאנלים",
      "פוטו-וולטאי",
      "PV",
      "photovoltaic",
      "solar",
      "חשמלאי",
      "חשמלאות",
      "תאורה",
      "תשתית חשמל",
      "בודק חשמל",
      "מערכת אגירה",
      "energy storage",
      "battery storage",
      "אינוורטר",
      "inverter",
      "התקנה חשמלית",
      "פיקוח חשמל"
    ],
    "exclude": [
      "תוצרת חוץ בלבד",
      "המנהל הצבאי בלבד"
    ]
  },

  "alert_thresholds_days": [30, 14, 7, 3, 1, 0],

  "deadline_parser": {
    "_comment": "Heuristics for parsing Hebrew dates",
    "patterns": [
      "DD.MM.YYYY",
      "DD/MM/YYYY",
      "DD-MM-YYYY",
      "ב-DD ב-MMMM",
      "עד תאריך"
    ]
  },

  "polling": {
    "user_agent": "BEE-tender-tracker/0.1 (contact: barak@bee.co.il)",
    "timeout_ms": 15000,
    "max_retries": 3,
    "delay_between_sources_ms": 2000
  },

  "logging": {
    "log_file": "./tender-tracker.log",
    "level": "info"
  }
}
